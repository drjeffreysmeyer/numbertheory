<proposition xml:id="prop-2_2-3">
  <title>Bezout Identity</title>
  <statement>
    <p>
      If <m>a,b\in \Z</m> then there exists <m>x,y\in \Z</m> so that <m>ax+by = \gcd(a,b)</m>.   
    </p>
  </statement>
  <proof>
    <p>
      ggg
    </p>
  </proof>
</proposition>

</section>